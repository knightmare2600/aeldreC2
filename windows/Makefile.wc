# =================================================================
# OBJ_UTILS_SOCKETS — utils objects needing sk_*/logevent.
# Included in all network-capable targets but NOT puttygen.
# =================================================================

OBJ_UTILS_SOCKETS = &
	backend_socket_log.obj &
	logeventf.obj &
	x11authfile.obj &
