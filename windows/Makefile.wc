# =================================================================
# Default target
# =================================================================

all: pageant.exe plink.exe pscp.exe psftp.exe putty.exe puttygen.exe puttytel.exe winsftp.exe ncwfw.exe ncnt.exe joshua.exe tank.exe tank16.exe clu.exe grid.exe gridcli.exe ipcalc32.exe ipcalc16.exe markuped.exe wget.exe wget16.exe lightman.exe flynn.exe svcany.exe regcli.exe whoami.exe arp.exe stager.exe clip.exe clip16.exe timestmp.exe yori16.exe yori32.exe yoriview.exe jloshtog.exe dumont.exe netstatN.exe "net-stat.exe" net_stat.exe route.exe route16.exe setup16.exe lman16.exe nc16.exe grid16.exe grid32.exe gridnt.exe .SYMBOLIC

win32s: pageant.exe putty.exe puttytel.exe puttygen.exe winsftp.exe ncwfw.exe joshua.exe tank.exe tank16.exe ipcalc16.exe clu.exe grid.exe gridcli.exe ipcalc32.exe markuped.exe wget.exe wget16.exe flynn.exe setup16.exe setup32.exe .SYMBOLIC

dist: all setup32.exe .SYMBOLIC
	sh -c "mkdir -p ../output/compiled ../output/exe"
	python3 ../tools/mksetup.py --out16 output/exe/setup16.exe
	cp setup32.exe ../output/exe/setup32.exe
	python3 ../help/mkhlp.py ../output/compiled/aeldreC2.HLP
	cp joshua.exe tank.exe tank16.exe clu.exe grid.exe gridcli.exe ipcalc32.exe ipcalc16.exe markuped.exe wget.exe wget16.exe lightman.exe flynn.exe ncwfw.exe ncnt.exe svcany.exe regcli.exe whoami.exe arp.exe stager.exe clip.exe clip16.exe timestmp.exe yori16.exe yori32.exe yoriview.exe jloshtog.exe dumont.exe netstatN.exe "net-stat.exe" net_stat.exe route.exe route16.exe lman16.exe nc16.exe grid16.exe grid32.exe gridnt.exe putty.exe puttytel.exe puttygen.exe winsftp.exe pageant.exe aelctl.dll ../output/compiled/
	sh -c "cd ../output && zip -9 -j aeldrec2-tools.zip compiled/*.exe compiled/*.dll compiled/aeldreC2.HLP exe/setup16.exe exe/setup32.exe ../README.md && echo 'Created: output/aeldrec2-tools.zip'"

# =================================================================
# Per-platform distribution targets
# dist-wfw   : Win16 NE executables for WFW 3.11 / Windows 3.1
# dist-win32 : Win32 GUI-subsystem PE — Win32s + Win95 + NT
# dist-nt    : Win32 NT console + advanced-API — NT 3.1+ and Win95
# dist-all   : all three platform folders
# =================================================================

dist-wfw: tank16.exe net_stat.exe route16.exe ipcalc16.exe wget16.exe yori16.exe setup16.exe clip16.exe lman16.exe nc16.exe grid16.exe $(INNO_DONE) .SYMBOLIC
	sh -c "mkdir -p ../output/wfw"
	cp tank16.exe net_stat.exe route16.exe ipcalc16.exe wget16.exe yori16.exe setup16.exe clip16.exe lman16.exe nc16.exe grid16.exe ../output/wfw/
	cp ../dist/CTL3DV2.DLL ../output/wfw/

dist-win32: joshua.exe tank.exe clu.exe flynn.exe ncwfw.exe grid.exe clip.exe wget.exe ipcalc32.exe markuped.exe yori32.exe jloshtog.exe setup32.exe "net-stat.exe" aelctl.dll .SYMBOLIC
	sh -c "mkdir -p ../output/win32s"
	cp joshua.exe tank.exe clu.exe flynn.exe ncwfw.exe grid.exe clip.exe wget.exe ipcalc32.exe markuped.exe yori32.exe jloshtog.exe setup32.exe "net-stat.exe" aelctl.dll ../output/win32s/
	cp ../dist/COMDLG32.DLL ../dist/WSOCK32.DLL ../output/win32s/

dist-nt: gridcli.exe ncnt.exe netstatN.exe route.exe svcany.exe regcli.exe whoami.exe arp.exe stager.exe timestmp.exe yoriview.exe dumont.exe lightman.exe grid32.exe gridnt.exe .SYMBOLIC
	sh -c "mkdir -p ../output/nt"
	cp gridcli.exe ncnt.exe netstatN.exe route.exe svcany.exe regcli.exe whoami.exe arp.exe stager.exe timestmp.exe yoriview.exe dumont.exe lightman.exe grid32.exe gridnt.exe ../output/nt/

dist-all: dist-wfw dist-win32 dist-nt .SYMBOLIC

# =================================================================
# be_list.c — per-target compilation with different defines
# =================================================================

be_list_putty.obj: ../be_list.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) &
	    -DAPPNAME=PuTTY -DSSH=1 -DSERIAL=1 -DOTHERBACKENDS=1 &
	    -fo=be_list_putty.obj -c ../be_list.c

be_list_puttytel.obj: ../be_list.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) &
	    -DAPPNAME=PuTTYtel -DSSH=0 -DSERIAL=1 -DOTHERBACKENDS=1 &
	    -fo=be_list_puttytel.obj -c ../be_list.c

be_list_plink.obj: ../be_list.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) &
	    -DAPPNAME=Plink -DSSH=1 -DSERIAL=1 -DOTHERBACKENDS=1 &
	    -fo=be_list_plink.obj -c ../be_list.c

be_list_pscp.obj: ../be_list.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) &
	    -DAPPNAME=PSCP -DSSH=1 -DSERIAL=0 -DOTHERBACKENDS=0 &
	    -fo=be_list_pscp.obj -c ../be_list.c

be_list_psftp.obj: ../be_list.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) &
	    -DAPPNAME=PSFTP -DSSH=1 -DSERIAL=0 -DOTHERBACKENDS=0 &
	    -fo=be_list_psftp.obj -c ../be_list.c

# =================================================================
# Resource compilation
# =================================================================

pageant.res: pageant.rc
	$(RCPATH) $(RCFLAGS) pageant.rc -o pageant.res

putty.res: putty.rc
	$(RCPATH) $(RCFLAGS) putty.rc -o putty.res

puttytel.res: puttytel.rc
	$(RCPATH) $(RCFLAGS) puttytel.rc -o puttytel.res

plink.res: plink.rc
	$(RCPATH) $(RCFLAGS) plink.rc -o plink.res

pscp.res: pscp.rc
	$(RCPATH) $(RCFLAGS) pscp.rc -o pscp.res

psftp.res: psftp.rc
	$(RCPATH) $(RCFLAGS) psftp.rc -o psftp.res

puttygen.res: puttygen.rc
	$(RCPATH) $(RCFLAGS) puttygen.rc -o puttygen.res

