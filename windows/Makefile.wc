# =================================================================
# AeldreC2 NT toolkit tools (console subsystem, advapi32/wsock32)
# =================================================================

CTOOL_CC = $(CC) -bt=nt -l=nt -za99 -ox -D_WIN32

# NT_STUB: inject ntstub.exe as the DOS stub in NT-only console PE tools.
# When launched under DOS/Win32s/COMMAND.COM the stub prints
# "Requires Windows NT 3.1 or later" instead of the default gibberish.
# wcl386 passes -"option ..." verbatim to wlink; \" preserves the quotes
# through the shell so wcl386 receives the literal -"..." syntax it expects.
NT_STUB = -\"option stub=ntstub.exe\"

ntstub.exe: ntstub.asm
	wasm -ms -fo=ntstub.obj ntstub.asm
	wlink system dos file ntstub.obj name ntstub.exe

# NT toolkit tools — compile rules (.exe rules with icons are below)
ncnt.obj: ncnt.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c ncnt.c

svcany.obj: svcany.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c svcany.c

regcli.obj: regcli.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c regcli.c

whoami.obj: whoami.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c whoami.c

arp.obj: arp.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c arp.c

stager.obj: stager.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c stager.c

clip.obj: clip.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c clip.c

# timestmp.exe -- file timestamp manipulation (8.3: timestmp)
timestmp.obj: timestmp.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c timestmp.c

timestmp.res: timestmp.rc timestmp.ico
	$(RCPATH) $(RCFLAGS) timestmp.rc -o timestmp.res

timestmp.exe: timestmp.obj timestmp.res ntstub.exe
	$(CTOOL_CC) $(NT_STUB) -fe=$@ timestmp.obj
	wrc timestmp.res $@

# --- add icons to console NT tools that have .rc files ---

ncnt.res: ncnt.rc ncnt.ico
	$(RCPATH) $(RCFLAGS) ncnt.rc -o ncnt.res

ncnt.exe: ncnt.obj ncnt.res ntstub.exe
	$(CTOOL_CC) $(NT_STUB) -fe=$@ ncnt.obj wsock32.lib
	wrc ncnt.res $@

svcany.res: svcany.rc svcany.ico
	$(RCPATH) $(RCFLAGS) svcany.rc -o svcany.res

svcany.exe: svcany.obj svcany.res ntstub.exe
	$(CTOOL_CC) $(NT_STUB) -fe=$@ svcany.obj advapi32.lib
	wrc svcany.res $@

regcli.res: regcli.rc regcli.ico
	$(RCPATH) $(RCFLAGS) regcli.rc -o regcli.res

regcli.exe: regcli.obj regcli.res ntstub.exe
	$(CTOOL_CC) $(NT_STUB) -fe=$@ regcli.obj advapi32.lib
	wrc regcli.res $@

whoami.res: whoami.rc whoami.ico
	$(RCPATH) $(RCFLAGS) whoami.rc -o whoami.res

whoami.exe: whoami.obj whoami.res ntstub.exe
	$(CTOOL_CC) $(NT_STUB) -fe=$@ whoami.obj advapi32.lib netapi32.lib
	wrc whoami.res $@

arp.res: arp.rc arp.ico
	$(RCPATH) $(RCFLAGS) arp.rc -o arp.res

arp.exe: arp.obj arp.res ntstub.exe
	$(CTOOL_CC) $(NT_STUB) -fe=$@ arp.obj wsock32.lib
	wrc arp.res $@

stager.res: stager.rc stager.ico
	$(RCPATH) $(RCFLAGS) stager.rc -o stager.res

stager.exe: stager.obj stager.res ntstub.exe
	$(CTOOL_CC) $(NT_STUB) -fe=$@ stager.obj wsock32.lib
	wrc stager.res $@

clip.res: clip.rc clip.ico
	$(RCPATH) $(RCFLAGS) clip.rc -o clip.res

clip.exe: clip.obj clip.res
	$(CTOOL_CC) -fe=$@ clip.obj user32.lib
	wrc clip.res $@

gridcli.res: gridcli.rc gridcli.ico
	$(RCPATH) $(RCFLAGS) gridcli.rc -o gridcli.res

gridcli.exe: gridcli.obj gridcli.res ntstub.exe
	$(CC) -bt=nt -l=nt $(NT_STUB) -fe=$@ $(LDFLAGS) gridcli.obj wsock32.lib
	wrc gridcli.res $@

# =================================================================
# netstatN.exe -- NT 3.1+ console netstat (iphlpapi or exec fallback)
# net-stat.exe -- Win9x / Win32s GUI dialog netstat (iphlpapi or COMMAND.COM fallback)
# net_stat.exe -- Win16 WFW 3.11 GUI dialog netstat (COMMAND.COM exec)
# route.exe    -- NT 3.1+ console route table
# route16.exe  -- Win16 WFW 3.11 GUI dialog route table
# =================================================================

netstatN.obj: netstatN.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c netstatN.c

netstat.res: netstat.rc ncnt.ico
	$(RCPATH) $(RCFLAGS) netstat.rc -o netstat.res

netstatN.exe: netstatN.obj netstat.res ntstub.exe
	$(CTOOL_CC) $(NT_STUB) -fe=$@ netstatN.obj wsock32.lib advapi32.lib
	wrc netstat.res $@

"net-stat.obj": "net-stat.c"
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c "net-stat.c"

"net-stat.exe": "net-stat.obj" netstat.res
	$(CC) -bt=nt -l=nt_win -fe=$@ $(LDFLAGS) "net-stat.obj" wsock32.lib
	wrc netstat.res $@

net_stat.obj: net_stat.c
	wcc -ml -bt=windows -zu -s -I/opt/watcom/h/win $(XFLAGS) -fo=$@ net_stat.c

net_stat.exe: net_stat.obj
	wlink system windows name net_stat.exe file net_stat.obj

route.obj: route.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c route.c

route.res: route.rc arp.ico
	$(RCPATH) $(RCFLAGS) route.rc -o route.res

route.exe: route.obj route.res ntstub.exe
	$(CTOOL_CC) $(NT_STUB) -fe=$@ route.obj wsock32.lib advapi32.lib
	wrc route.res $@

route16.obj: route16.c
	wcc -ml -bt=windows -zu -s -I/opt/watcom/h/win $(XFLAGS) -fo=$@ route16.c

route16.exe: route16.obj
	wlink system windows name route16.exe file route16.obj

clip16.obj: clip16.c
	wcc -ml -bt=windows -zu -s -I/opt/watcom/h/win $(XFLAGS) -fo=$@ clip16.c

clip16.exe: clip16.obj
	wlink system windows name clip16.exe file clip16.obj

# Convenience target: build all NT tools at once
nt-tools: ncnt.exe svcany.exe regcli.exe whoami.exe arp.exe stager.exe clip.exe timestmp.exe netstatN.exe route.exe .SYMBOLIC

# =================================================================
# Yori: remote screen viewer / control
# yori16.exe -- Win16 server (WFW 3.11, Win 3.11 — no Win32s needed)
# yori32.exe -- Win32s/Win95/NT server  (both share yori.ico = Malcolm McDowell/Alex)
# yoriview.exe -- Win32 operator viewer (codename: the_universal)
# =================================================================

yori.res: yori.rc yori.ico
	$(RCPATH) $(RCFLAGS) yori.rc -o yori.res

yori16.obj: yori_srv.c
	wcc -ml -bt=windows -zu -s -DYORI_WIN16 -I/opt/watcom/h/win -fo=$@ yori_srv.c

yori16.res: yori.rc yori.ico
	wrc -q -bt=windows -r -fo=$@ yori.rc

yori16.exe: yori16.obj yori16.res
	wlink system windows name yori16.exe file yori16.obj library winsock.lib
	wrc yori16.res $@

yori32.obj: yori_srv.c
	$(CC) $(COMPAT) $(CFLAGS) -DYORI_WIN32 -fo=$@ -c yori_srv.c

yori32.exe: yori32.obj yori.res
	$(CC) -bt=nt -l=nt_win -fe=$@ $(LDFLAGS) yori32.obj wsock32.lib
	wrc yori.res $@

yoriview.obj: yoriview.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c yoriview.c

yoriview.res: yoriview.rc yoriview.ico
	$(RCPATH) $(RCFLAGS) yoriview.rc -o yoriview.res

yoriview.exe: yoriview.obj yoriview.res
	$(CC) -bt=nt -l=nt_win -fe=$@ $(LDFLAGS) yoriview.obj wsock32.lib user32.lib
	wrc yoriview.res $@

yori: yori16.exe yori32.exe yoriview.exe .SYMBOLIC

# dumont.exe -- network mapper (the Tower Guardian)
dumont.obj: dumont.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c dumont.c

dumont.res: dumont.rc dumont.ico
	$(RCPATH) $(RCFLAGS) dumont.rc -o dumont.res

dumont.exe: dumont.obj dumont.res
	$(CC) -bt=nt -l=nt_win -fe=$@ $(LDFLAGS) dumont.obj comdlg32.lib
	wrc dumont.res $@

# jloshtog.exe -- Joshua log viewer (outwith the main controller)
jloshtog.obj: jloshtog.c
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -fo=$@ -c jloshtog.c

jloshtog.res: jloshtog.rc jloshtog.ico
	$(RCPATH) $(RCFLAGS) jloshtog.rc -o jloshtog.res

jloshtog.exe: jloshtog.obj jloshtog.res
	$(CC) -bt=nt -l=nt_win -fe=$@ $(LDFLAGS) jloshtog.obj comdlg32.lib
	wrc jloshtog.res $@

# =================================================================
# Icon generation
#
# Each .ico depends on the source image in icons/.  Updating the
# PNG/WEBP/JPG source and rebuilding will regenerate the .ico,
# which causes the .res and .exe to rebuild automatically.
#
# Force-regenerate everything:  wmake -f Makefile.wc icons
# =================================================================

icons: &
    arp.ico clip.ico dumont.ico flynn.ico grid.ico gridcli.ico &
    ipcalc.ico jloshtog.ico joshua.ico lightcycle.ico lightman.ico &
    markuped.ico ncnt.ico ncwfw.ico reco.ico regcli.ico stager.ico &
    svcany.ico tank.ico timestmp.ico wget.ico whoami.ico &
    yori.ico yoriview.ico &
    .SYMBOLIC

arp.ico: ../icons/arp.png
	$(ICON_CONV) ../icons/arp.png arp.ico

dumont.ico: ../icons/dumont.png
	$(ICON_CONV) ../icons/dumont.png dumont.ico

jloshtog.ico: ../icons/jloshtog.png
	$(ICON_CONV) ../icons/jloshtog.png jloshtog.ico

clip.ico: ../icons/clip.png
	$(ICON_CONV) ../icons/clip.png clip.ico

flynn.ico: ../icons/flynn.png
	$(ICON_CONV) ../icons/flynn.png flynn.ico

grid.ico: ../icons/grid.png
	$(ICON_CONV) ../icons/grid.png grid.ico

gridcli.ico: ../icons/gridcli.png
	$(ICON_CONV) ../icons/gridcli.png gridcli.ico

ipcalc.ico: ../icons/ipcalc.png
	$(ICON_CONV) ../icons/ipcalc.png ipcalc.ico

joshua.ico: ../icons/joshua.png
	$(ICON_CONV) ../icons/joshua.png joshua.ico

lightcycle.ico: ../icons/LIGHTCYCLE.PNG
	$(ICON_CONV) ../icons/LIGHTCYCLE.PNG lightcycle.ico

lightman.ico: ../icons/lightman.png
	$(ICON_CONV) ../icons/lightman.png lightman.ico

markuped.ico: ../icons/markuped.png
	$(ICON_CONV) ../icons/markuped.png markuped.ico

ncnt.ico: ../icons/ncnt.png
	$(ICON_CONV) ../icons/ncnt.png ncnt.ico

ncwfw.ico: ../icons/WOPR.jpg
	$(ICON_CONV) ../icons/WOPR.jpg ncwfw.ico

reco.ico: ../icons/RECO.webp
	$(ICON_CONV) ../icons/RECO.webp reco.ico

regcli.ico: ../icons/regcli.png
	$(ICON_CONV) ../icons/regcli.png regcli.ico

stager.ico: ../icons/stager.png
	$(ICON_CONV) ../icons/stager.png stager.ico

svcany.ico: ../icons/svcany.png
	$(ICON_CONV) ../icons/svcany.png svcany.ico

tank.ico: ../icons/TANK.webp
	$(ICON_CONV) ../icons/TANK.webp tank.ico

timestmp.ico: ../icons/timestmp.png
