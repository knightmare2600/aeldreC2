# =================================================================
# setup16.exe -- Win16 self-extracting installer
# Compiled with 16-bit wcc (large model, Windows target).
# After build, run: python3 ../tools/mksetup.py  to bundle EXEs.
# =================================================================

WCC16    = wcc
WLINK16  = wlink
WRC16    = wrc

setup16.obj: setup16.c
	$(WCC16) -ml -bt=windows -zu -s -I/opt/watcom/h/win -fo=$@ setup16.c

setup16.res: setup16.rc ../gpl30.txt
	$(WRC16) -q -bt=windows -r -I/opt/watcom/h/win -fo=$@ setup16.rc

setup16.exe: setup16.obj setup16.res
	$(WLINK16) system windows name $@ file setup16.obj library commdlg.lib
	$(WRC16) setup16.res $@

# =================================================================
# setup32.exe -- InnoSetup 1.2.16 installer
# Requires: innoextract + wine (both present in the Docker build image)
# =================================================================

INNO_DIST = ../dist/isetup16-1.2.16.exe
INNO_DIR  = /tmp/aeldrec2-inno
INNO_DONE = inno16.done

$(INNO_DONE): $(INNO_DIST)
	sh -c "mkdir -p $(INNO_DIR) && innoextract -d $(INNO_DIR) $(INNO_DIST) && cp $(INNO_DIR)/app/SAMPLE16/CTL3DV2.DLL ../dist/CTL3DV2.DLL && touch $(INNO_DONE)"

setup32.exe: setup32.iss $(INNO_DONE)
	sh ../tools/run_inno16.sh $(INNO_DIR)/app/COMPIL16.EXE setup32.iss setup32.exe

# =================================================================
# aelctl.dll — Win32s-compatible common controls shim
#
# Provides msctls_progress32, msctls_statusbar32, msctls_updown32.
# On Win95/NT4+: delegates to COMCTL32.DLL when present.
# On Win32s/NT3.1: registers GDI-based shim window classes.
#
# All Win32 targets that need COMCTL32 controls link aelctl.lib
# instead of comctl32.lib; source code is unchanged.
# =================================================================

aelctl.obj: aelctl.c aelctl.h
	$(CC) $(COMPAT) $(CFLAGS) $(XFLAGS) -bd -DAELCTL_BUILD_DLL -fo=$@ -c aelctl.c

aelctl.lib: aelctl.obj
	wlink system nt_dll initinstance terminstance &
	    name aelctl.dll &
	    file aelctl.obj &
	    option implib=aelctl.lib

# =================================================================
# Clean
# =================================================================

clean: .SYMBOLIC
	-$(RM) -f *.obj *.exe *.res *.err *.map aelctl.dll aelctl.lib

